#!/usr/bin/env bash
# =============================================================================
#  exegol-menu.sh — Exegol container manager
# =============================================================================
set -Eeuo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'
YELLOW='\033[1;33m'; BOLD='\033[1m'; RESET='\033[0m'

ok()   { echo -e "${GREEN}[OK]${RESET}    $*"; }
info() { echo -e "${CYAN}[INFO]${RESET}  $*"; }
warn() { echo -e "${YELLOW}[WARN]${RESET}  $*"; }
err()  { echo -e "${RED}[ERROR]${RESET} $*"; }
die()  { err "$*"; exit 1; }

banner() {
echo -e "${BOLD}${CYAN}"
cat << 'BANNER'
            Made by: z1rov
          OSCP | OSCP+ | BSCP
Repo: https://github.com/z1rov/dotfiles
BANNER
echo -e "${RESET}"
}

usage() {
  banner
  echo -e "${BOLD}USAGE${RESET}"
  echo -e "  $(basename "$0") [OPTIONS]"
  echo ""
  echo -e "${BOLD}OPTIONS${RESET}"
  echo -e "  ${CYAN}-h${RESET}              Show this help"
  echo -e "  ${CYAN}-l${RESET}              List Exegol images locally"
  echo -e "  ${CYAN}-i <image>${RESET}      Specify image tag (default: auto-detect)"
  echo -e "  ${CYAN}-n <name>${RESET}       Container name (default: exegol-session)"
  echo -e "  ${CYAN}-s${RESET}              Start container (creates if missing)"
  echo -e "  ${CYAN}-S${RESET}              Stop container"
  echo -e "  ${CYAN}-e${RESET}              Exec into running container"
  echo -e "  ${CYAN}-t${RESET}              Status — running containers + disk usage"
  echo -e "  ${CYAN}-L${RESET}              Logs (last 50 lines)"
  echo ""
  echo -e "${BOLD}EXAMPLES${RESET}"
  echo -e "  $(basename "$0") -s                  Start with auto-detected image"
  echo -e "  $(basename "$0") -s -i full-3.1.6    Start specific image"
  echo -e "  $(basename "$0") -e                  Shell into running container"
  echo -e "  $(basename "$0") -t                  Check status"
  exit 0
}

# ── Defaults ──────────────────────────────────────────────────────────────────
IMAGE=""
CONTAINER_NAME="exegol-session"
ACTION=""

detect_image() {
  local img
  img=$(docker images --format "{{.Repository}}:{{.Tag}}" 2>/dev/null \
        | grep -i "exegol" | head -n1)
  [[ -z "$img" ]] && die "No Exegol image found locally."
  echo "$img"
}

resolve_image() {
  if [[ -z "$IMAGE" ]]; then
    IMAGE=$(detect_image)
    info "Auto-detected image: ${BOLD}${IMAGE}${RESET}"
  else
    local full="nwodtuhs/exegol:${IMAGE}"
    docker images --format "{{.Repository}}:{{.Tag}}" | grep -q "^${full}$" \
      && IMAGE="$full" \
      || die "Image '${IMAGE}' not found. Use -l to list available."
    info "Using image: ${BOLD}${IMAGE}${RESET}"
  fi
}

container_exists()  { docker ps -a --format "{{.Names}}" 2>/dev/null | grep -q "^${CONTAINER_NAME}$"; }
container_running() { docker ps    --format "{{.Names}}" 2>/dev/null | grep -q "^${CONTAINER_NAME}$"; }

# ── Actions ───────────────────────────────────────────────────────────────────
action_list() {
  info "Exegol images available locally:"
  echo ""
  docker images --format "table {{.Repository}}\t{{.Tag}}\t{{.ID}}\t{{.Size}}" \
    | grep -E "REPOSITORY|exegol" || warn "No Exegol images found."
  echo ""
}

action_start() {
  resolve_image

  if container_running; then
    ok "Container '${CONTAINER_NAME}' is already running"
    return
  fi

  if container_exists; then
    info "Container exists but stopped — starting..."
    docker start "$CONTAINER_NAME" > /dev/null
    sleep 1
    container_running && ok "Container '${CONTAINER_NAME}' started" || die "Failed to start container"
    return
  fi

  info "Creating container '${CONTAINER_NAME}'..."
  # Use the image's own entrypoint — just keep stdin open
  docker run -dit \
    --name "$CONTAINER_NAME" \
    --network host \
    --privileged \
    --entrypoint /bin/bash \
    "$IMAGE"

  sleep 1
  container_running \
    && ok "Container '${CONTAINER_NAME}' is running" \
    || die "Container exited immediately — check: docker logs ${CONTAINER_NAME}"
}

action_stop() {
  container_running || die "Container '${CONTAINER_NAME}' is not running"
  docker stop "$CONTAINER_NAME" > /dev/null
  ok "Container '${CONTAINER_NAME}' stopped"
}

action_exec() {
  container_running || die "Container '${CONTAINER_NAME}' is not running. Start it with -s"
  info "Entering '${CONTAINER_NAME}'..."
  docker exec -it "$CONTAINER_NAME" /bin/bash
}

action_status() {
  echo ""
  info "Exegol containers:"
  docker ps -a --format "table {{.Names}}\t{{.Image}}\t{{.Status}}" \
    | grep -E "NAMES|exegol" || warn "No Exegol containers found"
  echo ""
  info "Disk usage (images):"
  docker images --format "table {{.Repository}}\t{{.Tag}}\t{{.Size}}" \
    | grep -E "REPOSITORY|exegol" || true
  echo ""
}

action_logs() {
  container_exists || die "Container '${CONTAINER_NAME}' does not exist"
  docker logs --tail 50 "$CONTAINER_NAME"
}

# ── Parse args ────────────────────────────────────────────────────────────────
[[ $# -eq 0 ]] && usage

while getopts ":hlsSeLti:n:" opt; do
  case "$opt" in
    h) usage ;;
    i) IMAGE="$OPTARG" ;;
    n) CONTAINER_NAME="$OPTARG" ;;
    l) ACTION="list" ;;
    s) ACTION="start" ;;
    S) ACTION="stop" ;;
    e) ACTION="exec" ;;
    t) ACTION="status" ;;
    L) ACTION="logs" ;;
    :) die "Option -${OPTARG} requires an argument" ;;
    ?) die "Unknown option: -${OPTARG} — use -h for help" ;;
  esac
done

banner
[[ -z "$ACTION" ]] && die "No action specified. Use -h for help"

case "$ACTION" in
  list)   action_list ;;
  start)  action_start ;;
  stop)   action_stop ;;
  exec)   action_exec ;;
  status) action_status ;;
  logs)   action_logs ;;
esac
