#!/usr/bin/env bash
# Author: z1rov
set -Eeuo pipefail

USER_NAME="${SUDO_USER:-${USER:-$(id -un)}}"
SUDO_FILE="/etc/sudoers.d/99_${USER_NAME}"
DOTFILES_REPO="https://github.com/z1rov/dotfiles"
KON_REPO="https://github.com/z1rov/kon"
BLACKARCH_STRAP="https://blackarch.org/strap.sh"
SELF_TARGET="/usr/bin/installer"
REDS=("52" "88" "124" "160" "196" "203")
LOGFILE="/tmp/zirov-install-$(date +%s).log"
ERROR_LOG="/tmp/zirov-error-$(date +%s).log"
touch "$LOGFILE" 2>/dev/null || LOGFILE="/dev/null"
touch "$ERROR_LOG" 2>/dev/null || ERROR_LOG="/dev/null"
ERROR_COUNT=0

FIREFOX_CONFIG_DIR="$HOME/.config/mozilla/firefox"
FIREFOX_CACHE_DIR="$HOME/.cache/mozilla/firefox"
FIREFOX_INI="$FIREFOX_CONFIG_DIR/profiles.ini"
FIREFOX_INSTALLS="$FIREFOX_CONFIG_DIR/installs.ini"
FIREFOX_SRC_DIR="$HOME/.config/firefox"
FIREFOX_PROFILE_DIR=""

PACMAN_PKGS=(
  xorg xorg-xinit bspwm sxhkd picom feh ly
  kitty zsh tmux neovim rofi thunar gvfs ttf-jetbrains-mono
  bat eza xclip brightnessctl pamixer firefox
  pipewire pipewire-pulse wireplumber papirus-icon-theme
  dunst flameshot gnome-themes-extra nano tree ttf-jetbrains-mono-nerd
  linux linux-firmware mesa opencl-mesa xf86-video-amdgpu polybar nodejs npm
  openvpn unzip zip htop jq fastfetch
)

YAY_PKGS=( i3lock-color ttf-hack-nerd ttf-firacode-nerd nordic-theme papirus-folders bibata-cursor-theme-bin )

ART=(
'╔╦═╗ ╔══╗ ╔═╦═╗ ╔══╗ ═╦═ ╦    ╔══╗ ╔══╗'
' ║ ║ ║  ║   ║   ║     ║  ║    ║    ║   '
' ║ ║ ║  ║   ║   ╠═╣   ║  ║    ╠═╣  ╚══╗'
' ║ ║ ║  ║   ║   ║     ║  ║    ║       ║'
'═╩═╝ ╚══╝   ╩   ╩    ═╩═ ╚══╝ ╚══╝ ╚══╝'
)

_supports_color() {
  [[ -t 1 ]] || return 1
  command -v tput &>/dev/null || return 1
  local n
  n="$(tput colors 2>/dev/null || echo 0)"
  [[ "$n" -ge 8 ]]
}

if _supports_color; then
  COLOR_ENABLED=1
  REDRAW_ENABLED=1
  CLR_OK="\033[38;5;82m"
  CLR_ERR="\033[0;31m"
  CLR_INFO="\033[38;5;196m"
  CLR_WARN="\033[0;36m"
  CLR_META="\033[38;5;135m"
  CLR_ACCENT="\033[38;5;226m"
  CLR_DIM="\033[2m"
  CLR_BOLD="\033[1m"
  CLR_RESET="\033[0m"
else
  COLOR_ENABLED=0
  REDRAW_ENABLED=0
  CLR_OK=""
  CLR_ERR=""
  CLR_INFO=""
  CLR_WARN=""
  CLR_META=""
  CLR_ACCENT=""
  CLR_DIM=""
  CLR_BOLD=""
  CLR_RESET=""
fi

_ok()   { echo -e "  ${CLR_OK}[+]${CLR_RESET} $*"; }

_err() {
  echo -e "  ${CLR_ERR}[-]${CLR_RESET} $*"
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$ERROR_LOG"
  ERROR_COUNT=$((ERROR_COUNT + 1))
}

_info() { echo -e "  ${CLR_INFO}[*]${CLR_RESET} $*"; }
_warn() { echo -e "  ${CLR_WARN}[~]${CLR_RESET} $*"; }
_dim()  { echo -e "  ${CLR_DIM}$*${CLR_RESET}"; }
_bold() { echo -e "  ${CLR_BOLD}$*${CLR_RESET}"; }
_blank() { echo; }
_divider() { echo -e "  ${CLR_DIM}$(printf '%.0s─' {1..48})${CLR_RESET}"; }

_typewriter() {
  local text="$1" color="$2" delay="${3:-0.08}"
  local ch
  for ch in $(echo "$text" | grep -o .); do
    if [[ "$COLOR_ENABLED" -eq 1 ]]; then
      printf "%b%s%b" "$color" "$ch" "$CLR_RESET"
    else
      printf "%s" "$ch"
    fi
    sleep "$delay"
  done
  echo
}

_print_art() {
  local i=0 line color
  for line in "${ART[@]}"; do
    if [[ "$COLOR_ENABLED" -eq 1 ]]; then
      color="${REDS[$((i % ${#REDS[@]}))]}"
      printf "  \033[38;5;%sm%s\033[0m\n" "$color" "$line"
    else
      echo "  $line"
    fi
    i=$((i + 1))
  done
}

_banner() {
  clear
  _blank
  _print_art
  printf "        "
  _typewriter "Alone" "$CLR_ACCENT"
  _blank
  echo -e "  ${CLR_META}[Meta]${CLR_RESET} Created by z1rov"
  echo -e "  ${CLR_META}[Meta]${CLR_RESET} ${CLR_DIM}https://www.zirov.net${CLR_RESET}"
  echo -e "  ${CLR_META}[Meta]${CLR_RESET} ${CLR_DIM}${DOTFILES_REPO}${CLR_RESET}"
  _blank
  if [[ "$REDRAW_ENABLED" -eq 1 ]]; then
    tput sc
  fi
}

_redraw() {
  if [[ "$REDRAW_ENABLED" -eq 1 ]]; then
    tput rc
    tput ed
  fi
}

_usage() {
  _banner
  echo -e "  ${CLR_INFO}[Info]${CLR_RESET} Usage: installer <command>"
  _blank
  echo -e "  \033[38;5;160m[setup       ]\033[0m${CLR_DIM}::${CLR_RESET} full install: bspwm, docker, zsh, dotfiles, theme, tooling"
  echo -e "  \033[38;5;160m[blackarch   ]\033[0m${CLR_DIM}::${CLR_RESET} add the blackarch repository"
  echo -e "  \033[38;5;160m[bloodhound  ]\033[0m${CLR_DIM}::${CLR_RESET} deploy BloodHound CE via docker compose"
  echo -e "  \033[38;5;160m[vmware      ]\033[0m${CLR_DIM}::${CLR_RESET} configure open-vm-tools if running in VMware"
  echo -e "  \033[38;5;160m[ssh         ]\033[0m${CLR_DIM}::${CLR_RESET} generate ssh keys"
  echo -e "  \033[38;5;160m[firefox     ]\033[0m${CLR_DIM}::${CLR_RESET} pin dedicated firefox profile and load custom environment"
  echo -e "  \033[38;5;160m[kon         ]\033[0m${CLR_DIM}::${CLR_RESET} clone and install kon"
  echo -e "  \033[38;5;220m[diagnose    ]\033[0m${CLR_DIM}::${CLR_RESET} check binaries, configs and logs"
  echo -e "  \033[38;5;220m[help        ]\033[0m${CLR_DIM}::${CLR_RESET} show this help"
  _blank
  _divider
  _blank
}

_require_not_root() {
  if [[ $EUID -eq 0 ]]; then
    _err "Do not run as root"
    exit 1
  fi
}

_confirm() {
  local prompt="$1" ans
  read -rp "  $prompt (Y/n): " ans
  ans=${ans,,}
  if [[ -n "$ans" && "$ans" != "y" && "$ans" != "yes" ]]; then
    return 1
  fi
  return 0
}

_setup_sudo() {
  if ! sudo -v; then
    _redraw
    _err "sudo authentication failed"
    exit 1
  fi

  sudo sh -c "echo '$USER_NAME ALL=(ALL) NOPASSWD: ALL' > '$SUDO_FILE'" &>>"$LOGFILE"
  sudo chmod 440 "$SUDO_FILE" &>>"$LOGFILE"

  if ! sudo visudo -cf "$SUDO_FILE" &>>"$LOGFILE"; then
    sudo rm -f "$SUDO_FILE"
    _redraw
    _err "invalid sudoers file, reverted"
    exit 1
  fi

  _redraw
  _ok "sudo NOPASSWD configured"
}

_self_install() {
  local src
  src="$(readlink -f "$0")"

  if [[ "$src" == "$SELF_TARGET" ]]; then
    _ok "installer already available as: installer"
    return
  fi

  if sudo cp "$src" "$SELF_TARGET" &>>"$LOGFILE" && sudo chmod +x "$SELF_TARGET"; then
    _ok "installer deployed globally, use it from anywhere as: installer"
  else
    _err "failed to deploy installer to $SELF_TARGET"
  fi
}

_install_pacman_quiet() {
  local pkg
  for pkg in "$@"; do
    if pacman -Qi "$pkg" &>/dev/null; then
      continue
    fi
    sudo pacman -S --needed --noconfirm "$pkg" &>>"$LOGFILE" || echo "$pkg"
  done
}

_setup_yay() {
  if command -v yay &>/dev/null; then
    return 0
  fi

  sudo pacman -S --needed --noconfirm git base-devel &>>"$LOGFILE"

  local tmpdir="/tmp/zirov-yay-$$"
  rm -rf "$tmpdir"

  if git clone https://aur.archlinux.org/yay.git "$tmpdir" &>>"$LOGFILE"; then
    (cd "$tmpdir" && makepkg -si --noconfirm &>>"$LOGFILE")
  fi

  rm -rf "$tmpdir"
  command -v yay &>/dev/null
}

_install_yay_quiet() {
  local pkg
  for pkg in "$@"; do
    if yay -Qi "$pkg" &>/dev/null; then
      continue
    fi
    yay -S --needed --noconfirm "$pkg" &>>"$LOGFILE" || echo "$pkg"
  done
}

_write_xinitrc() {
  {
    echo "[[ -f ~/.Xresources ]] && xrdb -merge ~/.Xresources"
    echo "exec bspwm"
  } > "$HOME/.xinitrc"
}

_setup_theme() {
  local gtk_dir="$HOME/.config/gtk-3.0"
  mkdir -p "$gtk_dir" "$HOME/.icons/default"

  cat > "$gtk_dir/settings.ini" <<-EOF
	[Settings]
	gtk-theme-name=Nordic
	gtk-icon-theme-name=Papirus-Dark
	gtk-cursor-theme-name=Bibata-Modern-Ice
	gtk-cursor-theme-size=24
	gtk-application-prefer-dark-theme=1
	EOF

  cat > "$HOME/.icons/default/index.theme" <<-EOF
	[Icon Theme]
	Inherits=Bibata-Modern-Ice
	EOF

  if ! grep -q "Xcursor.theme" "$HOME/.Xresources" 2>/dev/null; then
    {
      echo "Xcursor.theme: Bibata-Modern-Ice"
      echo "Xcursor.size: 24"
    } >> "$HOME/.Xresources"
  fi

  if command -v xrdb &>/dev/null && [[ -n "${DISPLAY:-}" ]]; then
    xrdb -merge "$HOME/.Xresources" &>>"$LOGFILE" || true
  fi

  if command -v papirus-folders &>/dev/null; then
    papirus-folders -C blue --theme Papirus-Dark &>>"$LOGFILE" && \
      _ok "papirus folders set to blue" || \
      _err "papirus-folders failed to set blue folders"
  else
    _err "papirus-folders not installed, skipping blue folder colors"
  fi

  if [[ -d "/usr/share/themes/Nordic" || -d "$HOME/.themes/Nordic" || -d "$HOME/.local/share/themes/Nordic" ]]; then
    _ok "Nordic GTK theme installed"
  else
    _err "Nordic GTK theme not found after install"
  fi

  if [[ -d "/usr/share/icons/Bibata-Modern-Ice" || -d "$HOME/.local/share/icons/Bibata-Modern-Ice" ]]; then
    _ok "Bibata-Modern-Ice cursor installed"
  else
    _err "Bibata-Modern-Ice cursor not found after install"
  fi

  _ok "theme configured (Nordic + Papirus blue + Bibata-Modern-Ice cursor)"
}

_setup_bspwm() {
  local failed_pacman failed_yay

  failed_pacman="$(_install_pacman_quiet "${PACMAN_PKGS[@]}")"

  if _setup_yay; then
    failed_yay="$(_install_yay_quiet "${YAY_PKGS[@]}")"
  else
    failed_yay="${YAY_PKGS[*]}"
  fi

  if [[ ! -f "$HOME/.xinitrc" ]]; then
    _write_xinitrc
  fi

  _setup_theme

  _redraw
  if [[ -z "$failed_pacman" ]]; then
    _ok "pacman packages installed"
  else
    _err "pacman packages failed: $(echo "$failed_pacman" | tr '\n' ' ')"
  fi

  if [[ -z "$failed_yay" ]]; then
    _ok "yay packages installed"
  else
    _err "yay packages failed: $(echo "$failed_yay" | tr '\n' ' ')"
  fi
}

_setup_blackarch() {
  if pacman -Sl blackarch &>/dev/null; then
    _ok "blackarch repo already configured"
    return
  fi

  local tmp
  tmp="$(mktemp)"
  if curl -fsSL "$BLACKARCH_STRAP" -o "$tmp" &>>"$LOGFILE" && sudo bash "$tmp" &>>"$LOGFILE"; then
    _ok "blackarch repository added"
  else
    _err "failed to add blackarch repository"
  fi
  rm -f "$tmp"
  sudo pacman -Sy &>>"$LOGFILE" || true
}

_setup_burpsuite() {
  local failed
  failed="$(_install_pacman_quiet burpsuite)"

  local found
  found="$(sudo find /usr -maxdepth 5 -type f -name burpsuite 2>/dev/null | head -n1)"
  [[ -z "$found" ]] && found="/usr/local/bin/burpsuite"

  if sudo tee "$found" >/dev/null <<'EOF'
#!/bin/sh
_JAVA_AWT_WM_NONREPARENTING=1 java \
  -Dswing.defaultlaf=javax.swing.plaf.metal.MetalLookAndFeel \
  -Dsun.java2d.opengl=false \
  -Dsun.java2d.xrender=false \
  -Dsun.java2d.pmoffscreen=false \
  -Dswing.noxp=true \
  -Dswing.metalTheme=steel \
  -jar /usr/share/burpsuite/burpsuite.jar "$@"
EOF
  then
    sudo chmod +x "$found"
    _ok "burpsuite launcher patched ($found)"
  else
    _err "failed to patch burpsuite launcher"
  fi

  if [[ -n "$failed" ]]; then
    _err "burpsuite package failed to install"
  fi
}

_setup_docker() {
  if command -v docker &>/dev/null; then
    _ok "docker already installed"
  else
    if sudo pacman -S --needed --noconfirm docker docker-compose &>>"$LOGFILE"; then
      _ok "docker installed"
    else
      _err "docker install failed"
      return
    fi
  fi

  sudo systemctl enable --now docker &>>"$LOGFILE" && _ok "docker service enabled" || _err "docker service enable failed"

  if ! getent group docker | grep -q "\b${USER_NAME}\b"; then
    if sudo usermod -aG docker "$USER_NAME"; then
      _ok "$USER_NAME added to docker group"
    else
      _err "failed to add $USER_NAME to docker group"
    fi
  else
    _ok "$USER_NAME already in docker group"
  fi

  sudo modprobe veth &>>"$LOGFILE" || _warn "veth module not loadable for kernel $(uname -r), reboot may be required for full docker networking"
}

_install_bloodhound() {
  local dir="$HOME/bloodhound-ce"
  mkdir -p "$dir"

  pushd "$dir" &>/dev/null || { _err "cannot create $dir"; return; }

  if [[ -f docker-compose.yml ]]; then
    _ok "BloodHound compose file already present"
  else
    if curl -fsSL https://ghst.ly/getbhce -o docker-compose.yml &>>"$LOGFILE"; then
      _ok "BloodHound compose file downloaded"
    else
      _err "failed to download BloodHound compose file"
      popd &>/dev/null || true
      return
    fi
  fi

  if ! grep -q "bhe_default_admin_password" docker-compose.yml; then
    sed -i '/Add additional environment variables you wish to use here/a\      - bhe_default_admin_principal_name=admin\n      - bhe_default_admin_password=${BH_ADMIN_PASSWORD:-Z1rovP@ss123!}' docker-compose.yml
    _ok "custom admin password injected into docker-compose.yml"
  fi

  if ! command -v docker &>/dev/null; then
    _err "docker not available, run: installer setup first"
    popd &>/dev/null || true
    return
  fi

  sudo modprobe veth &>>"$LOGFILE" || _warn "veth module unavailable, continuing with the default network driver"

  if BH_ADMIN_PASSWORD='Z1rovP@ss123!' bhe_recreate_default_admin=true docker compose up -d &>>"$LOGFILE"; then
    local tries=0 reachable=0
    while [[ $tries -lt 15 ]]; do
      if curl -fsS -o /dev/null "http://localhost:8080/ui/login" 2>>"$LOGFILE"; then
        reachable=1
        break
      fi
      sleep 2
      tries=$((tries + 1))
    done

    if [[ $reachable -eq 1 ]]; then
      _ok "BloodHound CE verified reachable on http://localhost:8080/ui/login"
      _ok "admin login -> user: admin | password: Z1rovP@ss123!"
    else
      _warn "BloodHound container started but did not respond in time, check manually"
    fi

    if docker compose down &>>"$LOGFILE"; then
      _ok "BloodHound containers stopped, start later with: docker compose up -d (inside $dir)"
    else
      _err "failed to stop BloodHound containers, stop manually with: docker compose down (inside $dir)"
    fi
  else
    _err "BloodHound docker compose failed (log: $LOGFILE)"
  fi

  popd &>/dev/null || true
}

_setup_display_manager() {
  if systemctl is-enabled ly &>/dev/null || systemctl is-active ly &>/dev/null; then
    _ok "ly already enabled"
    return
  fi

  local dm
  for dm in gdm sddm lightdm lxdm; do
    if systemctl is-enabled "$dm" &>/dev/null || systemctl is-active "$dm" &>/dev/null; then
      _warn "existing display manager detected ($dm), skipping ly activation"
      return
    fi
  done

  sudo systemctl enable ly &>>"$LOGFILE" && _ok "ly enabled" || _err "ly enable failed"
}

_setup_services() {
  sudo systemctl enable NetworkManager &>>"$LOGFILE" || true
  sudo systemctl start NetworkManager &>>"$LOGFILE" || true
  _setup_display_manager
  if [[ ! -f "$HOME/.xinitrc" ]]; then
    _write_xinitrc
  fi
  sudo chsh -s /bin/zsh "$USER_NAME" &>>"$LOGFILE" || true
  _ok "services configured"
}

_setup_zsh() {
  local failed
  failed="$(_install_pacman_quiet zsh)"

  if [[ ! -d "$HOME/.oh-my-zsh" ]]; then
    CHSH=no RUNZSH=no KEEP_ZSHRC=yes sh -c \
      "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" \
      "" --unattended &>>"$LOGFILE"
  fi

  local zsh_custom="$HOME/.oh-my-zsh/custom"
  git clone https://github.com/zsh-users/zsh-autosuggestions \
    "$zsh_custom/plugins/zsh-autosuggestions" &>>"$LOGFILE" || true
  git clone https://github.com/zsh-users/zsh-syntax-highlighting \
    "$zsh_custom/plugins/zsh-syntax-highlighting" &>>"$LOGFILE" || true

  sudo chsh -s /bin/zsh "$USER_NAME" &>>"$LOGFILE" || true

  _redraw
  if [[ -d "$HOME/.oh-my-zsh" && -z "$failed" ]]; then
    _ok "zsh installed and configured"
  else
    _err "zsh setup failed"
  fi
}

_setup_dotfiles() {
  local dotdir="$HOME/dotfiles"

  if [[ -d "$dotdir/.git" ]]; then
    git -C "$dotdir" pull &>>"$LOGFILE" && _ok "dotfiles updated" || _err "dotfiles update failed"
  else
    if git clone "$DOTFILES_REPO" "$dotdir" &>>"$LOGFILE"; then
      _ok "dotfiles cloned"
    else
      _err "dotfiles clone failed"
      return
    fi
  fi

  mkdir -p "$HOME/.config"

  if [[ -d "$dotdir/config" ]]; then
    cp -rf "$dotdir/config/." "$HOME/.config/"
    _ok "config/ deployed"
  fi
  if [[ -f "$dotdir/home/.zshrc" ]]; then
    cp "$dotdir/home/.zshrc" "$HOME/"
    _ok ".zshrc deployed"
  fi
  if [[ -d "$dotdir/home/.mozilla" ]]; then
    cp -r "$dotdir/home/.mozilla" "$HOME/"
    _ok ".mozilla deployed"
  fi
  if [[ -d "$dotdir/home/.local" ]]; then
    cp -r "$dotdir/home/.local" "$HOME/"
    _ok ".local deployed"
  fi

  if [[ -d "$dotdir/bin" ]]; then
    while IFS= read -r -d '' binfile; do
      local bname
      bname="$(basename "$binfile")"
      if [[ "$bname" == .* || "$bname" == README* || "$bname" == LICENSE* ]]; then
        continue
      fi
      if sudo cp "$binfile" "/usr/bin/$bname" &>>"$LOGFILE" && sudo chmod +x "/usr/bin/$bname"; then
        _ok "$bname deployed"
      else
        _err "$bname deploy failed"
      fi
    done < <(find "$dotdir/bin" -maxdepth 1 -type f -print0)
  fi

  if [[ -f "$HOME/.config/bspwm/bspwmrc" ]]; then
    chmod +x "$HOME/.config/bspwm/bspwmrc"
  fi
  if [[ -f "$HOME/.config/sxhkd/sxhkdrc" ]]; then
    chmod +x "$HOME/.config/sxhkd/sxhkdrc"
  fi
  if [[ -d "$HOME/.config/bspwm/scripts" ]]; then
    find "$HOME/.config/bspwm/scripts" -type f -exec chmod 755 {} \;
  fi

  mkdir -p "$HOME/Documents" "$HOME/Downloads" "$HOME/CTF"
  _ok "dotfiles deployed"
}

_setup_vmware() {
  if ! systemd-detect-virt --quiet --vm 2>/dev/null | grep -q vmware && \
     ! grep -qi "vmware" /sys/class/dmi/id/sys_vendor 2>/dev/null; then
    _warn "not running inside VMware, skipping"
    return
  fi

  if sudo pacman -S --needed --noconfirm open-vm-tools gtkmm3 &>>"$LOGFILE"; then
    _ok "open-vm-tools + gtkmm3 installed"
  else
    _err "open-vm-tools install failed"
    return
  fi

  sudo systemctl enable vmtoolsd.service &>>"$LOGFILE" || true
  sudo systemctl start vmtoolsd.service &>>"$LOGFILE" || true
  _ok "vmtoolsd enabled"

  sudo systemctl enable vmware-vmblock-fuse.service &>>"$LOGFILE" || true
  sudo systemctl start vmware-vmblock-fuse.service &>>"$LOGFILE" || true
  _ok "vmware-vmblock-fuse enabled"

  local bspwmrc="$HOME/.config/bspwm/bspwmrc"
  if [[ -f "$bspwmrc" ]]; then
    if ! grep -q "vmware-user" "$bspwmrc"; then
      {
        echo ""
        echo "pgrep vmware-user || vmware-user &"
      } >> "$bspwmrc"
      _ok "vmware-user added to bspwmrc"
    else
      _ok "vmware-user already in bspwmrc"
    fi
  else
    _err "bspwmrc not found, add 'pgrep vmware-user || vmware-user &' manually"
  fi
}

_setup_root() {
  sudo chsh -s /bin/zsh root &>>"$LOGFILE" || true
  sudo cp -r "$HOME/.oh-my-zsh" /root/ &>>"$LOGFILE" || true
  sudo cp "$HOME/.zshrc" /root/ &>>"$LOGFILE" || true
  sudo cp -r "$HOME/.config" /root/ &>>"$LOGFILE" || true
  _ok "root synced"
}

_generate_ssh_key() {
  local path="$1" type="$2" bits="$3" pass="$4" ssh_user="$5"

  if [[ -f "$path" ]]; then
    read -rp "  [!] $path exists, overwrite? (y/N): " ow
    if [[ "${ow,,}" != "y" ]]; then
      return
    fi
    cp "$path" "$path.bak" 2>/dev/null || true
    cp "$path.pub" "$path.pub.bak" 2>/dev/null || true
    rm -f "$path" "$path.pub"
  fi

  if [[ "$type" == "rsa" ]]; then
    ssh-keygen -t rsa -b "$bits" -f "$path" -C "${ssh_user}@$(hostname)" -N "$pass" -q
  else
    ssh-keygen -t ed25519 -f "$path" -C "${ssh_user}@$(hostname)" -N "$pass" -q
  fi

  chmod 600 "$path"
  chmod 644 "$path.pub"
  _ok "$type key generated"
}

_setup_ssh() {
  _confirm "Generate SSH keys?" || return

  local default_user="$USER_NAME"
  _blank
  _dim "1) Default  - no passphrase"
  _dim "2) Secure   - with passphrase (recommended)"
  read -rp "  Select option [1]: " mode
  if [[ "$mode" != "2" ]]; then
    mode=1
  fi

  read -rp "  SSH key label [${default_user}]: " ssh_user
  ssh_user="${ssh_user:-$default_user}"

  mkdir -p "$HOME/.ssh"
  chmod 700 "$HOME/.ssh"

  local pass_rsa="" pass_ed25519=""

  if [[ "$mode" == "2" ]]; then
    while true; do
      read -s -p "  RSA passphrase: " p1; echo
      read -s -p "  Confirm: " p2; echo
      if [[ "$p1" == "$p2" ]]; then
        pass_rsa="$p1"
        break
      fi
      _err "passphrases do not match"
    done

    read -s -p "  ED25519 passphrase (ENTER = reuse RSA): " q1; echo
    if [[ -z "$q1" ]]; then
      pass_ed25519="$pass_rsa"
    else
      while true; do
        read -s -p "  Confirm ED25519: " q2; echo
        if [[ "$q1" == "$q2" ]]; then
          pass_ed25519="$q1"
          break
        fi
        _err "passphrases do not match"
      done
    fi
  fi

  _generate_ssh_key "$HOME/.ssh/id_rsa"     "rsa"     4096 "$pass_rsa"     "$ssh_user"
  _generate_ssh_key "$HOME/.ssh/id_ed25519" "ed25519" ""   "$pass_ed25519" "$ssh_user"

  if [[ -f "$HOME/.ssh/id_rsa.pub" ]]; then
    _blank
    _dim "--- id_rsa.pub ---"
    cat "$HOME/.ssh/id_rsa.pub"
  fi

  if [[ -f "$HOME/.ssh/id_ed25519.pub" ]]; then
    _blank
    _dim "--- id_ed25519.pub ---"
    cat "$HOME/.ssh/id_ed25519.pub"
  fi
}

_confirm_firefox_wipe() {
  local ans
  _blank
  _warn "This will close Firefox and DELETE every profile except the dedicated one."
  _warn "All your current Firefox data (history, bookmarks, sessions, other profiles) will be LOST."
  _info "A fresh environment (custom homepage + userChrome/userContent) will be loaded instead."
  read -rp "  Continue? (Y/n): " ans
  ans=${ans,,}
  if [[ -n "$ans" && "$ans" != "y" && "$ans" != "yes" ]]; then
    return 1
  fi
  return 0
}

_ensure_firefox_profile() {
  local z1rov_path
  z1rov_path=$(grep -oP '(?<=Path=)\S*\.z1rov' "$FIREFOX_INI" 2>/dev/null | head -n1) || true
  if [[ -n "$z1rov_path" ]]; then
    echo "$z1rov_path"
    return 0
  fi

  mkdir -p "$FIREFOX_CONFIG_DIR"
  firefox -CreateProfile "z1rov" &>>"$LOGFILE" || true
  sleep 1
  pkill -9 firefox 2>/dev/null || true
  sleep 1

  z1rov_path=$(grep -oP '(?<=Path=)\S*\.z1rov' "$FIREFOX_INI" 2>/dev/null | head -n1) || true
  if [[ -z "$z1rov_path" ]]; then
    return 1
  fi
  echo "$z1rov_path"
  return 0
}

_pin_firefox_profile() {
  pkill -9 firefox 2>/dev/null || true
  sleep 1

  local z1rov_path
  if ! z1rov_path=$(_ensure_firefox_profile); then
    _err "failed to find or create a .z1rov profile"
    return 1
  fi
  _ok "z1rov profile: $z1rov_path"

  local install_hash
  if [[ -f "$FIREFOX_INSTALLS" ]]; then
    install_hash=$(grep -oP '(?<=^\[)[0-9A-Fa-f]+(?=\])' "$FIREFOX_INSTALLS" | head -n1) || true
  fi
  if [[ -z "${install_hash:-}" ]]; then
    install_hash=$(head -c 16 /dev/urandom | md5sum | cut -c1-16 | tr 'a-f' 'A-F')
  fi

  local dir name
  for dir in "$FIREFOX_CONFIG_DIR"/*.default-release "$FIREFOX_CONFIG_DIR"/*.default; do
    [[ -e "$dir" ]] || continue
    name=$(basename "$dir")
    rm -rf "$FIREFOX_CONFIG_DIR/$name" "$FIREFOX_CACHE_DIR/$name"
  done

  cat > "$FIREFOX_INI" <<EOF
[Install${install_hash}]
Default=${z1rov_path}
Locked=1

[Profile0]
Name=z1rov
IsRelative=1
Path=${z1rov_path}
Default=1

[General]
StartWithLastProfile=1
Version=2
EOF

  cat > "$FIREFOX_INSTALLS" <<EOF
[${install_hash}]
Default=${z1rov_path}
Locked=1
EOF

  FIREFOX_PROFILE_DIR="$FIREFOX_CONFIG_DIR/$z1rov_path"
  _ok "z1rov profile pinned as default ($z1rov_path)"
}

_deploy_firefox_env() {
  local user_name="$1"

  if [[ ! -d "$FIREFOX_SRC_DIR" ]]; then
    _err "$FIREFOX_SRC_DIR not found, run: installer setup first"
    return 1
  fi

  mkdir -p "$FIREFOX_PROFILE_DIR/chrome"

  if [[ -d "$FIREFOX_SRC_DIR/chrome" ]]; then
    cp -f "$FIREFOX_SRC_DIR/chrome/"*.css "$FIREFOX_PROFILE_DIR/chrome/" 2>>"$LOGFILE" && \
      _ok "userChrome.css / userContent.css deployed" || \
      _err "failed to deploy chrome/ files"
  else
    _err "$FIREFOX_SRC_DIR/chrome not found"
  fi

  if [[ -f "$FIREFOX_SRC_DIR/user.js" ]]; then
    sed "s#file:///home/<user>/#file:///home/${user_name}/#g" "$FIREFOX_SRC_DIR/user.js" > "$FIREFOX_PROFILE_DIR/user.js"
    _ok "user.js deployed (homepage pointed at $user_name)"
  else
    _err "$FIREFOX_SRC_DIR/user.js not found"
  fi

  if [[ -f "$FIREFOX_SRC_DIR/index.html" ]]; then
    sed -i "s/const z1rovUser = \"User\";/const z1rovUser = \"${user_name}\";/" "$FIREFOX_SRC_DIR/index.html"
    _ok "index.html username patched ($user_name)"
  else
    _err "$FIREFOX_SRC_DIR/index.html not found"
  fi
}

_setup_firefox() {
  _bold "Firefox environment"

  _confirm_firefox_wipe || { _info "cancelled"; return; }

  local user_name
  user_name="$(whoami)"
  _info "detected user: $user_name"

  _pin_firefox_profile || return

  _deploy_firefox_env "$user_name"

  _blank
  if [[ "$ERROR_COUNT" -gt 0 ]]; then
    _warn "firefox setup finished with errors, see $ERROR_LOG"
  else
    _ok "firefox environment ready, open with: firefox"
  fi
}

_install_kon() {
  local dir="/tmp/kon-$$"
  rm -rf "$dir"

  if git clone "$KON_REPO" "$dir" &>>"$LOGFILE"; then
    _ok "kon cloned"
  else
    _err "kon clone failed"
    return
  fi

  pushd "$dir" &>/dev/null || { _err "cannot enter $dir"; return; }

  if make install &>>"$LOGFILE"; then
    _ok "kon installed"
  else
    _err "kon make install failed (log: $LOGFILE)"
  fi

  popd &>/dev/null || true
  rm -rf "$dir"
}

_check_binary() {
  local bin="$1"
  if command -v "$bin" &>/dev/null; then
    _ok "$bin binary found"
  else
    _err "$bin binary missing"
  fi
}

_diagnose() {
  _bold "Diagnostics"

  local bin
  for bin in bspwm sxhkd kitty picom polybar rofi feh ly thunar tmux nvim dunst firefox node yay zsh docker burpsuite openvpn fastfetch; do
    _check_binary "$bin"
  done

  if [[ -f "$HOME/.xinitrc" ]] && grep -q "exec bspwm" "$HOME/.xinitrc"; then
    _ok ".xinitrc points to bspwm"
  else
    _err ".xinitrc missing or not launching bspwm"
  fi

  if [[ -x "$HOME/.config/bspwm/bspwmrc" ]]; then
    _ok "bspwmrc deployed and executable"
  else
    _err "bspwmrc missing or not executable, run: installer setup"
  fi

  if [[ -f "$HOME/.config/sxhkd/sxhkdrc" ]]; then
    _ok "sxhkdrc deployed"
  else
    _err "sxhkdrc missing, run: installer setup"
  fi

  if [[ -d "$HOME/.oh-my-zsh" ]]; then
    _ok "oh-my-zsh installed"
  else
    _err "oh-my-zsh missing"
  fi

  if [[ -f "$HOME/.config/gtk-3.0/settings.ini" ]] && grep -q "Nordic" "$HOME/.config/gtk-3.0/settings.ini"; then
    _ok "theme configured (Nordic + Bibata-Modern-Ice)"
  else
    _err "theme not configured, run: installer setup"
  fi

  if [[ -f "$HOME/bloodhound-ce/docker-compose.yml" ]]; then
    _ok "BloodHound compose file present"
  else
    _err "BloodHound compose file missing, run: installer bloodhound"
  fi

  if pacman -Sl blackarch &>/dev/null; then
    _ok "blackarch repo configured"
  else
    _err "blackarch repo missing, run: installer blackarch"
  fi

  if [[ -d "$FIREFOX_SRC_DIR" ]]; then
    _ok "firefox environment source present ($FIREFOX_SRC_DIR)"
  else
    _err "firefox environment source missing, run: installer setup"
  fi

  if [[ -x "$SELF_TARGET" ]]; then
    _ok "installer available globally as: installer"
  else
    _err "installer not deployed globally, run: installer setup"
  fi

  _blank
  if [[ "$ERROR_COUNT" -gt 0 ]]; then
    _warn "$ERROR_COUNT issue(s) found, details in $ERROR_LOG"
  else
    _ok "no issues found"
  fi
}

_ask_reboot() {
  _blank
  if _confirm "Reboot now?"; then
    _ok "rebooting..."
    sudo reboot
  else
    _info "reboot skipped, remember to reboot before relying on docker networking or new kernel modules"
  fi
}

_install_full() {
  _setup_sudo
  _self_install
  _setup_bspwm
  _setup_docker
  _setup_burpsuite
  _setup_services
  _setup_zsh
  _setup_dotfiles
  _setup_root

  _blank
  if [[ "$ERROR_COUNT" -gt 0 ]]; then
    _warn "installation finished with $ERROR_COUNT error(s), see $ERROR_LOG"
  else
    _ok "installation finished"
  fi

  _ask_reboot
}

_main() {
  local cmd="${1:-}"
  case "$cmd" in
    setup)
      _require_not_root
      _banner
      _confirm "Continue installation?" || exit 0
      _install_full
      ;;
    blackarch)
      _require_not_root
      _banner
      _setup_sudo
      _setup_blackarch
      ;;
    bloodhound)
      _require_not_root
      _banner
      _setup_sudo
      _install_bloodhound
      ;;
    vmware)
      _require_not_root
      _banner
      _setup_sudo
      _setup_vmware
      ;;
    ssh)
      _require_not_root
      _banner
      _setup_ssh
      ;;
    firefox)
      _require_not_root
      _banner
      _setup_firefox
      ;;
    kon)
      _require_not_root
      _banner
      _setup_sudo
      _install_kon
      ;;
    diagnose)
      _banner
      _diagnose
      _blank
      _divider
      _blank
      ;;
    help|-h|--help|"")
      _usage
      ;;
    *)
      _err "Unknown command: $cmd"
      _usage
      exit 1
      ;;
  esac
}

_main "$@"
